<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="18dp"
    android:layout_marginBottom="12dp">

    <TextView
        android:id="@+id/textServiceEmoji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🦷"
        android:textSize="32sp"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/textServiceName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Service Name"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:id="@+id/textServiceDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Description goes here"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="14dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginBottom="14dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/textServicePrice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="₱600"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"/>

        <TextView
            android:id="@+id/textServiceDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="30 min"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginEnd="12dp"/>

        <Button
            android:id="@+id/buttonBookNow"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_teal_pill"
            android:text="Book Now →"
            android:textColor="@color/teal_dark"
            android:textSize="12sp"
            android:paddingHorizontal="14dp"/>
    </LinearLayout>

</LinearLayout>
